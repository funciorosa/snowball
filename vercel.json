{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/check-signals",
      "schedule": "*/15 * * * *"
    }
  ]
}
